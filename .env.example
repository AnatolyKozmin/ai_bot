TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_CHANNELS=
TG_SESSION_NAME=
DB_PATH=
BACKFILL_LIMIT=
SAVE_ALL=
JOB_KEYWORDS=
# Полный URL эндпоинта, например https://your-api-host:8011/parse_post
LLM_API_URL=
# Секунды; не меньше OLLAMA_REQUEST_TIMEOUT на API + небольшой запас
LLM_API_TIMEOUT=360
# Тот же секрет, что INGEST_SECRET на ai_api (можно оставить пустым)
INGEST_SECRET=
# Свой системный промпт для Ollama (вместо встроенного в ai_api). Пустое значение = без системного блока.
# LLM_SYSTEM_PROMPT=
# Или путь к файлу с промптом (имеет приоритет над LLM_SYSTEM_PROMPT)
# LLM_SYSTEM_PROMPT_FILE=/path/to/prompt.txt